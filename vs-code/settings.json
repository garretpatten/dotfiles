{
  "diffEditor.ignoreTrimWhitespace": false,
  "editor.wordWrapColumn": 80,
  "editor.cursorBlinking": "solid",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.detectIndentation": false,
  "editor.fontSize": 16,
  "editor.inlineSuggest.suppressSuggestions": true,
  "editor.insertSpaces": false,
  "editor.fontFamily": "Fira Code",
  "editor.fontLigatures": true,
  "editor.fontWeight": "500",
  "editor.minimap.enabled": false,
  "editor.renderWhitespace": "all",
  "editor.tabSize": 4,
  "explorer.autoReveal": false,
  "explorer.compactFolders": false,
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.openEditors.visible": 1,
  "files.associations": {
    "*.component": "html",
    "*.cls": "apex",
    "*.page": "html",
    "*.app": "xml",
    "*.auradoc": "xml"
  },
  "files.exclude": {
    "base64.js": true
  },
  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": true,
  "problems.decorations.enabled": false,
  "search.quickOpen.includeHistory": false,
  "security.allowedUNCHosts": ["wsl.localhost"],
  "merge-conflict.autoNavigateNextConflict.enabled": true,
  "workbench.settings.editor": "json",
  "workbench.colorCustomizations": {
    "editor.selectionBackground": "#665c54",
    "editorLineNumber.foreground": "#92837491",
    "activityBarBadge.background": "#fe8019",
    "list.activeSelectionForeground": "#fabd2f",
    "list.inactiveSelectionForeground": "#fabd2f",
    "list.highlightForeground": "#fabd2f",
    "scrollbarSlider.activeBackground": "#fabd2f50",
    "editorSuggestWidget.highlightForeground": "#fabd2f",
    "textLink.foreground": "#83a598",
    "progressBar.background": "#fe8019",
    "pickerGroup.foreground": "#fabd2f",
    "tab.activeBorder": "#fabd2f",
    "notificationLink.foreground": "#83a598",
    "editorWidget.resizeBorder": "#fabd2f",
    "editorWidget.border": "#665c54",
    "settings.modifiedItemIndicator": "#fe8019",
    "settings.headerForeground": "#fabd2f",
    "panelTitle.activeBorder": "#fabd2f",
    "breadcrumb.activeSelectionForeground": "#fabd2f",
    "menu.selectionForeground": "#fabd2f",
    "menubar.selectionForeground": "#fabd2f"
  },
  "workbench.editor.enablePreviewFromQuickOpen": false,
  "workbench.sideBar.location": "right",
  "security.workspace.trust.untrustedFiles": "open",
  "workbench.iconTheme": "material-icon-theme",
  "workbench.colorTheme": "Gruvbox Dark Hard"
}
